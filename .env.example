# ──────────────────────────────────────────────────────
# PostProd Bot — переменные окружения
# Скопируй в .env и заполни (сам .env не заливай в GitHub!)
# ──────────────────────────────────────────────────────

# 1. Telegram бот-токен от @BotFather
TELEGRAM_TOKEN=7412345678:AAHxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. OpenAI API ключ (для GPT-4o-mini и Whisper)
#    platform.openai.com → API Keys → Create new key
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. Notion Internal Integration Token
#    notion.so/my-integrations → New integration → скопируй токен
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Notion Database IDs (уже созданы, не менять!) ──────
NOTION_TASKS_DB=f9f3a6736e81473e8a64ff6000833119
NOTION_PROJECTS_DB=7e7b1e5c0323430cac6bc22c8f26c875
NOTION_PATTERNS_DB=01f7f279ef1442bb83f95c114bde90b0

# ── Telegram Chat IDs для дайджестов и алертов ─────────
# Узнать ID чата: добавь @userinfobot в чат, напиши /start
# Для супергрупп формат: -100XXXXXXXXXX (через запятую если несколько)
DIGEST_CHAT_IDS=-100123456789

# ── Настройки (опционально) ────────────────────────────
DIGEST_HOUR=9            # Час утреннего дайджеста (0-23)
WAITING_ALERT_DAYS=2     # Через сколько дней пинговать об ожидании
